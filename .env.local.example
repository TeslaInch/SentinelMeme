# Free at moralis.io — Sign up → Web3 APIs → Copy API key
# Used for token metadata and holder data on BNB Chain
MORALIS_API_KEY=your_moralis_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ALCHEMY_API_KEY=your_alchemy_api_key_here
#BSC_RPC_URL=https://bsc-rpc.publicnode.com
# dGrid AI API key — Sign up at dgrid.ai
DGRID_API_KEY=your_dgrid_api_key_here
BSC_RPC_URL=your_bsc_rpc_url_here

# Create a bot at @BotFather on Telegram, copy the token it gives you
# Get your chat ID by messaging @userinfobot on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# BSC testnet wallet private key for on-chain attestations
# Create a NEW throwaway wallet — never use your main wallet
# Get free testnet BNB at testnet.bnbchain.org/faucet-smart

ATTESTATION_PRIVATE_KEY=your_attestation_private_key_here
ATTESTATION_CONTRACT_ADDRESS=your_attestation_contract_address_here
NEXT_PUBLIC_ATTESTATION_CONTRACT_ADDRESS=your_contract_address_here
